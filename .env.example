GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: override storage paths for each machine/user.
FB_JOB_DATA_DIR=./data
FB_COOKIES_PATH=./data/fb_cookies.json
FB_DATABASE_PATH=./data/jobs.db
FB_REPORT_DIR=./reports
FB_CV_PATH=./resume/cv.txt
FB_CV_VI_PATH=./resume/cv_vi.txt

# Optional: used only by scripts/auto_login.py.
# Leaving these empty lets you log in manually in the browser window.
FB_EMAIL=
FB_PASSWORD=
